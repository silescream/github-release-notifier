# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# Database (used by app)
DATABASE_URL=postgresql://notifier:changeme@localhost:5433/notifier

# PostgreSQL credentials (used by docker-compose postgres service)
POSTGRES_USER=notifier
POSTGRES_PASSWORD=changeme
POSTGRES_DB=notifier

# GitHub API (optional — 60 req/hr without token, 5000 req/hr with token)
GITHUB_TOKEN=

# SMTP (optional — emails are logged to console if not configured)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@releases.app

# Public URL used in email links
APP_BASE_URL=http://localhost:3000

# API key for endpoint authentication (optional)
# If set, GET /api/subscriptions requires X-API-Key header.
# Other endpoints remain open — confirm/unsubscribe links arrive via email
# in a browser where adding custom headers is not possible.
API_KEY=

# Redis URL for caching (optional — uses in-memory fallback if not set)
REDIS_URL=
